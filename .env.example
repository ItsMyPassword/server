# --- Network ---
PORT=8080
HOST=0.0.0.0

# Trust X-Forwarded-* when behind Caddy/Traefik/nginx.
TRUST_PROXY=true

# Comma-separated origins allowed by CORS. Leave empty to disable CORS entirely.
# Example: CORS_ORIGINS=chrome-extension://abcdef..,https://my.itsmypassword.app
CORS_ORIGINS=

# --- Storage ---
DATABASE_PATH=/data/itsmypassword.db

# --- Logging ---
# One of: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# --- Secrets ---
# 32-byte HMAC key (base64). Used to hash emails and IPs at rest.
# Generate once and KEEP STABLE — rotating it invalidates all stored hashes.
#   openssl rand -base64 32
SERVER_HMAC_KEY=replace_me_base64_32_bytes
